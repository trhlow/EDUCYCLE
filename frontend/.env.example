# Sao chép thành `.env.local` nếu cần (đã gitignore).
#
# Đăng ký / đăng nhập: chỉ email .edu.vn + OTP gửi về hộp thư trường (không OAuth).
#
# Proxy Vite → backend (mặc định trong vite.config.js):
#   VITE_DEV_PROXY_TARGET=http://localhost:8080
#
# Gọi API trực tiếp (ít dùng khi dev):
# VITE_API_BASE_URL=http://localhost:8080/api

# Feature flag: bật/tắt ảnh hero từ Unsplash proxy backend.
# VITE_ENABLE_UNSPLASH_HERO=true
