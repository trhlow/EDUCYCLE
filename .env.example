# Copy to .env next to docker-compose.yml (optional)
# docker compose reads JWT_SECRET from environment
#
# Bắt buộc cho `docker compose` (không còn mật khẩu Postgres mặc định trong compose).
POSTGRES_PASSWORD=educycle123

JWT_SECRET=replace_with_long_random_string_min_32_chars
APP_FRONTEND_BASE_URL=http://localhost

# Tuỳ chọn — CORS + SockJS (danh sách origin cách nhau bởi dấu phẩy). Mặc định trong application.yml đủ cho local.
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Chỉ CI E2E API (profile ci + jar): OTP cố định để Playwright không đọc email — không bật ngoài CI.
# EDUCYCLE_E2E_FIXED_OTP=123456

# Tuỳ chọn — Prometheus scrape không JWT (chỉ khi reverse proxy / mạng nội bộ bảo vệ)
# EDUCYCLE_PROMETHEUS_PUBLIC=false

# Tuỳ chọn — tắt job hết hạn giao dịch tự động (mặc định bật)
# EDUCYCLE_TRANSACTIONS_EXPIRY_ENABLED=false

# Tuỳ chọn — bật phản hồi Claude thật (không set = chatbot trả lời “chưa cấu hình”)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Tuỳ chọn — embeddings RAG (OpenAI). Không set = chatbot vẫn chạy với system prompt cố định, không truy xuất chunk DB
# OPENAI_API_KEY=sk-...

# Tuỳ chọn — email thật (OTP, quên mật khẩu): thêm profile smtp + MAIL_* (xem README)
# SPRING_PROFILES_ACTIVE=production,smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=your_gmail_app_password
# APP_MAIL_FROM=EduCycle <you@gmail.com>
