### STATUS_CONFIG pattern
```javascript
const STATUS_CONFIG = {
  PENDING:   { label: 'Chờ xác nhận', color: 'warning', icon: '⏳', step: 1 },
  ACCEPTED:  { label: 'Đã chấp nhận', color: 'info',    icon: '✅', step: 2 },
  MEETING:   { label: 'Đang gặp mặt', color: 'primary', icon: '🤝', step: 3 },
  COMPLETED: { label: 'Hoàn thành',   color: 'success', icon: '🎉', step: 4 },
  REJECTED:  { label: 'Từ chối',      color: 'error',   icon: '❌', step: -1 },
  CANCELLED: { label: 'Đã hủy',       color: 'neutral', icon: '🚫', step: -1 },
};
const statusKey = transaction?.status?.toUpperCase() ?? 'PENDING';
const config = STATUS_CONFIG[statusKey] ?? STATUS_CONFIG.PENDING;
```

### WebSocket (STOMP)
```javascript
import { createChatClient, sendChatMessage } from '../api/websocket';

const client = createChatClient(token, transactionId, (newMsg) => {
  setMessages(prev => prev.some(m => m.id === newMsg.id) ? prev : [...prev, newMsg]);
});
client.activate();

// Prefer WS, fallback HTTP
if (stompClientRef.current?.connected) {
  sendChatMessage(stompClientRef.current, transactionId, content);
} else {
  await messagesApi.send(transactionId, { content });
}

return () => { client.deactivate(); }; // always cleanup
```

### localStorage — safeSession.js utilities only
```javascript
import { loadAuthSession, clearAuthStorage } from '../utils/safeSession';
// Keys: 'token' · 'refreshToken' · 'user' (JSON { id, username, email, role })
```

