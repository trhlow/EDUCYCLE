# Copy to .env.local for local development. Do not commit real values.

# Local app profile
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/educycledb
SPRING_DATASOURCE_USERNAME=educycle
SPRING_DATASOURCE_PASSWORD=
JWT_SECRET=

# Docker DB profile. docker compose reads this file via env_file.
POSTGRES_DB=educycledb
POSTGRES_USER=educycle
POSTGRES_PASSWORD=

# Optional local defaults
APP_FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
