{
  "name": "educycle-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.js",
    "build": "vite build --config config/vite.config.js",
    "typecheck": "tsc -b",
    "lint": "eslint --config config/eslint.config.js .",
    "format": "prettier --config config/prettier.config.json --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "test": "vitest run --config config/vitest.config.js",
    "test:watch": "vitest --config config/vitest.config.js",
    "test:coverage": "vitest run --coverage --config config/vitest.config.js",
    "test:e2e": "playwright test -c config/playwright.config.mjs",
    "test:e2e:api": "playwright test -c config/playwright.api-ci.config.mjs",
    "preview": "vite preview --config config/vite.config.js",
    "prepare": "husky",
    "gitnexus:analyze": "gitnexus analyze . --skills"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --config config/prettier.config.json --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sockjs-client": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gitnexus": "^1.5.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
