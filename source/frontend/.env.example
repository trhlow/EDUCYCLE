# ╔══════════════════════════════════════════════════════════╗
# ║         HƯỚNG DẪN CẤU HÌNH OAUTH — EDUCYCLE             ║
# ╚══════════════════════════════════════════════════════════╝
#
# SAO CHÉP file này thành  .env  rồi điền thông tin vào.
# File .env đã có trong .gitignore — KHÔNG commit lên git.
#
# ┌─────────────────────────────────────────────────────────┐
# │  BƯỚC 1: Tạo Google OAuth App                           │
# └─────────────────────────────────────────────────────────┘
#  1. Vào: https://console.cloud.google.com/
#  2. Tạo project mới (hoặc chọn project có sẵn)
#  3. Menu trái → APIs & Services → Credentials
#  4. + CREATE CREDENTIALS → OAuth client ID
#  5. Application type: Web application
#  6. Name: EduCycle Local
#  7. Authorized JavaScript origins:
#       http://localhost:5173
#       http://localhost:3000
#  8. Authorized redirect URIs:
#       http://localhost:5173
#       http://localhost:5173/oauth-callback
#  9. Nhấn CREATE → Copy "Client ID" (dạng xxx.apps.googleusercontent.com)
# 10. Dán vào VITE_GOOGLE_CLIENT_ID bên dưới
#
# ┌─────────────────────────────────────────────────────────┐
# │  BƯỚC 2: Tạo Microsoft Azure OAuth App                  │
# └─────────────────────────────────────────────────────────┘
#  1. Vào: https://portal.azure.com/
#  2. Tìm "App registrations" → New registration
#  3. Name: EduCycle
#  4. Supported account types:
#       Chọn "Accounts in any organizational directory
#             AND personal Microsoft accounts"
#       (để cả Gmail trường + tài khoản cá nhân đều dùng được)
#  5. Redirect URI: Single-page application (SPA)
#       http://localhost:5173
#       http://localhost:5173/oauth-callback
#  6. Register → Copy "Application (client) ID"
#  7. Dán vào VITE_MICROSOFT_CLIENT_ID bên dưới
#
# ┌─────────────────────────────────────────────────────────┐
# │  BƯỚC 3: Cấu hình Backend                               │
# └─────────────────────────────────────────────────────────┘
#  Mở file: backend/educycle-java/src/main/resources/application.yml
#  Điền vào:
#    oauth:
#      google:
#        client-id: <giá trị VITE_GOOGLE_CLIENT_ID của bạn>
#      microsoft:
#        client-id: <giá trị VITE_MICROSOFT_CLIENT_ID của bạn>
#        tenant-id: common
#
# HOẶC set biến môi trường trước khi chạy backend:
#   Windows PowerShell:
#     $env:GOOGLE_CLIENT_ID="your-id.apps.googleusercontent.com"
#     $env:MICROSOFT_CLIENT_ID="your-azure-app-id"
#
# ══════════════════════════════════════════════════════════

# ── Frontend ───────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# Auth-code (mặc định): cần GOOGLE_CLIENT_SECRET trên BE. Dev không có secret → đặt false (implicit).
# VITE_GOOGLE_OAUTH_USE_AUTH_CODE=false
VITE_MICROSOFT_CLIENT_ID=YOUR_AZURE_APPLICATION_CLIENT_ID

# Tenant: "common" = cả tài khoản cá nhân + tổ chức
# Dùng tenant ID cụ thể của trường nếu muốn giới hạn
VITE_MICROSOFT_TENANT_ID=common

# ── Backend API URL ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api
