# Vite dev: proxy /api + /ws → Spring. Mặc định: Spring không profile (8080).
# Profile docker (8081): VITE_DEV_PROXY_TARGET=http://localhost:8081
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Optional: absolute API base (bypass Vite proxy). MUST include /api — app tự thêm nếu thiếu.
# Sai: VITE_API_URL=http://localhost:8080  → gây 404 (thiếu /api)
# Đúng: VITE_API_URL=http://localhost:8080/api
# VITE_API_URL=http://localhost:8080/api
