# Runtime env for deploy/docker-compose.deploy.yml
# Copy this file to server as: /opt/educycle/.env

POSTGRES_DB=educycledb
POSTGRES_USER=educycle
POSTGRES_PASSWORD=change_me

JWT_SECRET=change_me_with_long_random_string
APP_FRONTEND_BASE_URL=https://your-domain.example

APP_MAIL_REQUIRE_DELIVERY=true
SPRING_PROFILES_ACTIVE=production,smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-student-mail@your-university.edu.vn
MAIL_PASSWORD=your_app_password
APP_MAIL_FROM=EduCycle <your-student-mail@your-university.edu.vn>

EDUCYCLE_REDIS_ENABLED=true
UNSPLASH_ACCESS_KEY=
UNSPLASH_CACHE_TTL_SECONDS=21600
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
